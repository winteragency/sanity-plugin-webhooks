{
  "name": "sanity-plugin-webhooks",
  "version": "2.0.0",
  "description": "A tool that lists your Sanity webhooks and displays their events along with status, duration and response.",
  "keywords": [
    "sanity",
    "sanity-plugin",
    "webhooks",
    "realtime",
    "tool"
  ],
  "homepage": "https://github.com/winteragency/sanity-plugin-webhooks#readme",
  "bugs": {
    "url": "https://github.com/winteragency/sanity-plugin-webhooks/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/winteragency/sanity-plugin-webhooks.git"
  },
  "license": "MIT",
  "author": "Winter Agency <info@winteragency.se>",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "sanity.json",
    "src",
    "v2-incompatible.js"
  ],
  "scripts": {
    "build": "plugin-kit verify-package --silent && pkg-utils build --strict --check --clean",
    "format": "prettier --write --cache --ignore-unknown .",
    "link-watch": "plugin-kit link-watch",
    "lint": "eslint .",
    "prepublishOnly": "npm run build",
    "prepare": "lefthook install",
    "watch": "pkg-utils watch --strict",
    "check:types": "tsc --pretty --noEmit",
    "check:format": "prettier --check .",
    "fix:format": "prettier --write .",
    "fix:lint": "eslint src/ --fix --quiet"
  },
  "dependencies": {
    "@sanity/icons": "^3.7.4",
    "@sanity/incompatible-plugin": "^1.0.5",
    "@sanity/ui": "^3.1.13",
    "date-fns": "^4.1.0",
    "swr": "^2.4.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@eslint/js": "^9",
    "@sanity/pkg-utils": "^10.4.8",
    "@sanity/plugin-kit": "^4.0.20",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "conventional-changelog-conventionalcommits": "^9.3.0",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "lefthook": "^2.1.3",
    "prettier": "^3.8.1",
    "prettier-plugin-packagejson": "^3.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-is": "^19.2.4",
    "semantic-release": "^25.0.3",
    "semantic-release-license": "^1.0.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  },
  "peerDependencies": {
    "react": "^19",
    "sanity": "^5",
    "styled-components": "^6.1.8"
  },
  "engines": {
    "node": ">=18"
  },
  "lint-staged": {
    "*.js": "eslint --cache --fix"
  },
  "sanityPlugin": {
    "verifyPackage": {
      "eslintImports": false
    }
  },
  "browserslist": "extends @sanity/browserslist-config",
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "require": "./dist/index.cjs",
        "default": "./dist/index.js"
      },
      "./package.json": "./package.json"
    }
  }
}
